<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Beta>True</Beta>
  <Category>Downloaders: Other</Category>
  <Date>2026-05-01</Date>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/blizzardcldasl/subarr/master/unraid/subarr-icon.svg</Icon>
  <Name>Subarr</Name>
  <Repository>ghcr.io/blizzardcldasl/subarr:master</Repository>
  <Registry/>
  <Support>https://github.com/blizzardcldasl/subarr/issues</Support>
  <Project>https://github.com/blizzardcldasl/subarr</Project>
  <Overview>Lightweight YouTube subscription follower (*arr-style UI). RSS polling, webhooks, and optional yt-dlp downloads. Defaults: appdata /mnt/user/appdata/subarr, downloads /mnt/user/Youtube, Web UI host port 7979→container 3001. PUID/PGID match typical Unraid shares (nobody:users). No built-in auth—use LAN or reverse proxy.</Overview>
  <DonateText/>
  <DonateLink/>
  <WebUI>http://[IP]:[PORT:3001]/</WebUI>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <ExtraParams/>
  <PostArgs/>
  <DonateImg/>
  <BaseImage/>
  <Branch/>
  <License>MIT</License>
  <GitHub>https://github.com/blizzardcldasl/subarr</GitHub>
  <BindTime>true</BindTime>
  <Banner/>
  <Version>1</Version>
  <Config Name="Web UI" Target="3001" Default="7979" Mode="tcp" Description="Host port mapped to Subarr HTTP (container port 3001)" Type="Port" Display="always" Required="true" Mask="false">7979</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/subarr" Mode="rw" Description="SQLite DB and config (SUBARR_DB_PATH=/config/subarr.db)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/subarr</Config>
  <Config Name="Downloads" Target="/downloads" Default="/mnt/user/Youtube" Mode="rw" Description="yt-dlp output directory inside the container" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/Youtube</Config>
  <Config Name="SUBARR_DB_PATH" Target="SUBARR_DB_PATH" Default="/config/subarr.db" Mode="" Description="SQLite file path" Type="Variable" Display="advanced" Required="true" Mask="false">/config/subarr.db</Config>
  <Config Name="PORT" Target="PORT" Default="3001" Mode="" Description="Internal HTTP port (usually leave 3001)" Type="Variable" Display="advanced" Required="true" Mask="false">3001</Config>
  <Variable>
    <Value>99</Value>
    <Name>PUID</Name>
    <Mode/>
  </Variable>
  <Variable>
    <Value>100</Value>
    <Name>PGID</Name>
    <Mode/>
  </Variable>
</Container>
